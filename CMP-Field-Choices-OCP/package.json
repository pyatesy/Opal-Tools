    "test": "npx jest --passWithNoTests"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "@types/node-fetch": "^2.6.12",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@optimizely-opal/opal-tool-ocp-sdk": "^1.1.4",
    "@zaiusinc/app-sdk": "2.4.1",
    "@zaiusinc/node-sdk": "^2.0.0",
    "node-fetch": "^2.7.0"
  },
